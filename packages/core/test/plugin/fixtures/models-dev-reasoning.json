    "env": ["OPENAI_API_KEY"],
    "npm": "@ai-sdk/openai",
    "api": "https://api.openai.com/v1",
    "models": {
      "gpt-reasoning": {
        "id": "gpt-reasoning",
        "name": "GPT Reasoning",
        "release_date": "2026-01-01",
        "attachment": false,
        "reasoning": true,
        "reasoning_options": [
          { "type": "effort", "values": [null, "null", "low", "high"] },
          { "type": "budget_tokens", "min": 1024, "max": 64000 },
          { "type": "toggle" }
        ],
        "temperature": true,
        "tool_call": true,
        "limit": { "context": 128000, "output": 8192 },
        "experimental": {
          "modes": {
            "high": {
              "provider": {
                "headers": { "x-mode": "high" },
                "body": { "service_tier": "priority" }
              }
            },
            "pro": {
              "provider": {
                "body": { "reasoning": { "mode": "pro" } }
              }
            }
          }
        }
      }
    }
  },
